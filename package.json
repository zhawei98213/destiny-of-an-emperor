{
  "name": "destiny-of-an-emperor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "check:content": "vite-node tools/validate-content.ts",
    "validate-content": "vite-node tools/validate-content.ts",
    "import:all": "vite-node tools/import-all.ts",
    "import-all": "vite-node tools/import-all.ts",
    "import:sprites": "vite-node tools/run-import-sprites.ts",
    "import:maps": "vite-node tools/run-import-maps.ts",
    "import:text": "vite-node tools/run-import-text.ts",
    "import:data": "vite-node tools/run-import-data.ts",
    "parity-score": "vite-node tools/parity-score.ts",
    "battle-parity": "vite-node tools/battle-parity.ts",
    "discrepancy-triage": "vite-node tools/discrepancy-triage.ts",
    "test": "vitest run",
    "regression-smoke": "npm run import-all && npm run validate-content && vite-node tests/regression/runGoldenRegression.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  }
}
