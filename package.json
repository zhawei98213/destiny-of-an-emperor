{
  "name": "destiny-of-an-emperor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "check:content": "vite-node tools/validate-content.ts",
    "validate-content": "vite-node tools/validate-content.ts",
    "import:all": "vite-node tools/import-all.ts",
    "import-all": "vite-node tools/import-all.ts",
    "import:sprites": "vite-node tools/run-import-sprites.ts",
    "import:maps": "vite-node tools/run-import-maps.ts",
    "import:text": "vite-node tools/run-import-text.ts",
    "import:data": "vite-node tools/run-import-data.ts",
    "event-json": "vite-node tools/event-json.ts --check content/manual/story.content.json",
    "format:events": "vite-node tools/event-json.ts --write content/manual/story.content.json",
    "check:npc-placement": "vite-node tools/check-npc-placement.ts",
    "check:chapter-completeness": "vite-node tools/check-chapter-completeness.ts",
    "chapter-bootstrap": "vite-node tools/chapter-bootstrap.ts",
    "chapter-status-report": "vite-node tools/chapter-status-report.ts",
    "chapter-lock-checklist": "vite-node tools/chapter-lock-checklist.ts",
    "asset-check": "vite-node tools/asset-check.ts",
    "text-check": "vite-node tools/text-check.ts",
    "performance-baseline": "vite-node tools/performance-baseline.ts",
    "ui-parity": "vite-node tools/ui-parity.ts",
    "parity-score": "vite-node tools/parity-score.ts",
    "battle-parity": "vite-node tools/battle-parity.ts",
    "discrepancy-triage": "vite-node tools/discrepancy-triage.ts",
    "save-migration-check": "vitest run tests/runtime/saveMigration.test.ts tests/runtime/saveManager.test.ts",
    "pre-release-check": "vite-node tools/pre-release-check.ts",
    "pre-release-check:light": "vite-node tools/pre-release-check.ts --mode light",
    "pre-release-check:full": "vite-node tools/pre-release-check.ts --mode full",
    "test": "vitest run",
    "regression-smoke": "npm run import-all && npm run validate-content && vite-node tests/regression/runGoldenRegression.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  }
}
