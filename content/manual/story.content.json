{
  "meta": {
    "id": "manual-story",
    "kind": "manual",
    "version": 1,
    "description": "Hand-authored chapter slice dialogue, events, and shop definitions."
  },
  "dialogueLines": [
    {
      "id": "intro-line-1",
      "speakerName": "Village Guide",
      "speakerNpcId": "village-guide",
      "text": "The eastern road has reopened, but the patrols are still thin beyond the gate.",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "intro-line-2",
      "speakerName": "Village Guide",
      "speakerNpcId": "village-guide",
      "text": "Speak with the quartermaster, take the road pass, and be ready for the first skirmish outside town.",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "quartermaster-line-1",
      "speakerName": "Quartermaster",
      "speakerNpcId": "merchant",
      "text": "Supplies are short, but I can still issue one road pass for the eastern watch.",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant"
    },
    {
      "id": "quartermaster-line-2",
      "speakerName": "Quartermaster",
      "speakerNpcId": "merchant",
      "text": "Take this pass to the gate guard. Come back here if you need your strength restored.",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant"
    },
    {
      "id": "quartermaster-rest-line",
      "speakerName": "Quartermaster",
      "speakerNpcId": "merchant",
      "text": "Sit for a moment. I will mend your wounds and refill your travel pack.",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant"
    },
    {
      "id": "guard-line-blocked",
      "speakerName": "Town Guard",
      "speakerNpcId": "town-guard",
      "text": "Hold there. No one leaves the outpost without a sealed road pass.",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "guard-line-open",
      "speakerName": "Town Guard",
      "speakerNpcId": "town-guard",
      "text": "Pass confirmed. The eastern field is open, but stay alert once you leave the walls.",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "chest-line-open",
      "speakerName": "System",
      "text": "You found an Herb in the outpost supply chest.",
      "soundId": "sfx-chest"
    },
    {
      "id": "battle-start-line",
      "speakerName": "System",
      "text": "A roaming patrol spots you on the eastern road.",
      "soundId": "sfx-battle-alert"
    }
  ],
  "events": [
    {
      "id": "intro-event",
      "name": "Intro Event",
      "steps": [
        {
          "type": "dialogue",
          "lineId": "intro-line-1"
        },
        {
          "type": "dialogue",
          "lineId": "intro-line-2"
        },
        {
          "type": "setFlag",
          "flagId": "intro-complete",
          "value": true
        },
        {
          "type": "end"
        }
      ]
    },
    {
      "id": "merchant-pass-event",
      "name": "Merchant Pass Event",
      "steps": [
        {
          "type": "ifNotFlag",
          "flagId": "gate-pass",
          "steps": [
            { "type": "dialogue", "lineId": "quartermaster-line-1" },
            { "type": "dialogue", "lineId": "quartermaster-line-2" },
            { "type": "setFlag", "flagId": "merchant-met" },
            { "type": "setFlag", "flagId": "gate-pass" },
            { "type": "playSfx", "sfxId": "sfx-pass" },
            { "type": "end" }
          ]
        },
        {
          "type": "ifFlag",
          "flagId": "gate-pass",
          "steps": [
            { "type": "dialogue", "lineId": "quartermaster-rest-line" },
            { "type": "restoreParty" },
            { "type": "openShop", "shopId": "starter-shop" },
            { "type": "playSfx", "sfxId": "sfx-rest" },
            { "type": "end" }
          ]
        },
        { "type": "end" }
      ]
    },
    {
      "id": "guard-gate-event",
      "name": "Guard Gate Event",
      "steps": [
        {
          "type": "ifNotFlag",
          "flagId": "gate-pass",
          "steps": [
            { "type": "dialogue", "lineId": "guard-line-blocked" },
            { "type": "end" }
          ]
        },
        {
          "type": "ifFlag",
          "flagId": "gate-pass",
          "steps": [
            { "type": "dialogue", "lineId": "guard-line-open" },
            { "type": "warp", "targetMapId": "field", "targetSpawnId": "field-gate" },
            { "type": "end" }
          ]
        }
      ]
    },
    {
      "id": "town-chest-event",
      "name": "Town Chest Event",
      "steps": [
        { "type": "dialogue", "lineId": "chest-line-open" },
        { "type": "giveItem", "itemId": "herb", "quantity": 1 },
        { "type": "setFlag", "flagId": "town-chest-opened" },
        { "type": "playSfx", "sfxId": "sfx-chest" },
        { "type": "end" }
      ]
    },
    {
      "id": "training-battle-event",
      "name": "Training Battle Event",
      "steps": [
        { "type": "dialogue", "lineId": "battle-start-line" },
        { "type": "playSfx", "sfxId": "sfx-battle-alert" },
        { "type": "startBattle", "battleGroupId": "training-slimes" },
        { "type": "end" }
      ]
    }
  ],
  "shops": [
    {
      "id": "starter-shop",
      "name": "Quartermaster Supplies",
      "inventory": [
        {
          "itemId": "herb"
        },
        {
          "itemId": "bronze-sword",
          "price": 40
        }
      ]
    }
  ]
}
