{
  "meta": {
    "id": "manual-story",
    "kind": "manual",
    "version": 1,
    "description": "Hand-authored chapter slice dialogue, events, and shop definitions."
  },
  "dialogueLines": [
    {
      "id": "intro-line-1",
      "speakerName": "村长",
      "speakerNpcId": "village-guide",
      "text": "东边的道路虽然重新开放了，可城外巡逻的人手还是不够。",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "intro-line-2",
      "speakerName": "村长",
      "speakerNpcId": "village-guide",
      "text": "你先去找补给官拿路引，出村以后路上随时都可能遇到敌兵。",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "lou-sang-shop-line",
      "speakerName": "补给官",
      "speakerNpcId": "merchant",
      "text": "这里是村里的补给铺。今天能卖的只有草药和几把简陋的兵器。",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant"
    },
    {
      "id": "lou-sang-pass-line",
      "speakerName": "补给官",
      "speakerNpcId": "merchant",
      "text": "村长已经打过招呼了。这份路引你收好，出村时给守门兵验一眼就行。",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant"
    },
    {
      "id": "lou-sang-guard-blocked-line",
      "speakerName": "守门兵",
      "speakerNpcId": "town-guard",
      "text": "站住。没有县里送来的路引，谁也不能离开楼桑村。",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "lou-sang-guard-open-line",
      "speakerName": "守门兵",
      "speakerNpcId": "town-guard",
      "text": "印记没错，我这就打开东门。你准备好了就从路标那边出去吧。",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "lou-sang-exit-line-blocked",
      "speakerName": "系统",
      "text": "东门还没有打开，暂时不能出村。",
      "soundId": "sfx-blocked"
    },
    {
      "id": "lou-sang-chest-line-open",
      "speakerName": "系统",
      "text": "你在村长家的储物罐里找到了一份草药。",
      "soundId": "sfx-chest"
    },
    {
      "id": "field-east-road-line",
      "speakerName": "系统",
      "text": "你沿着东路继续前进，前方能看见一座供往来行人歇脚的小驿站。",
      "soundId": "sfx-step"
    },
    {
      "id": "road-scout-line",
      "speakerName": "巡路兵",
      "speakerNpcId": "road-scout",
      "text": "前面的驿站还能歇脚，再往东可就不太平了。若是伤了筋骨，记得先回驿站整顿。",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "relay-rest-line",
      "speakerName": "驿站医官",
      "speakerNpcId": "relay-healer",
      "text": "先坐下缓口气吧。我替你把伤药和水袋都补齐，再上路也不迟。",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant"
    },
    {
      "id": "relay-cache-line-open",
      "speakerName": "系统",
      "text": "你在驿站角落的木箱里找到了一把铜剑。",
      "soundId": "sfx-chest"
    },
    {
      "id": "relay-post-east-line",
      "speakerName": "系统",
      "text": "你离开驿站，继续沿着东侧山道前进，前方就是渡口。",
      "soundId": "sfx-step"
    },
    {
      "id": "ford-clerk-line-issue",
      "speakerName": "渡口文吏",
      "speakerNpcId": "ford-clerk",
      "text": "前头要验文符。驿站那边已经报过你的名字，这枚渡口文符你先收着。",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "ford-clerk-line-repeat",
      "speakerName": "渡口文吏",
      "speakerNpcId": "ford-clerk",
      "text": "文符已经发给你了。过河时把它交给守兵验过，别在路上弄丢。",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "ford-guard-line-blocked",
      "speakerName": "渡口守兵",
      "speakerNpcId": "ford-guard",
      "text": "前面就是临河营地，没有渡口文符一律不得通行。",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "ford-guard-line-open",
      "speakerName": "渡口守兵",
      "speakerNpcId": "ford-guard",
      "text": "文符没问题，前面的木桥给你留着。顺着桥面过去就是前营。",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "ford-crossing-line-blocked",
      "speakerName": "系统",
      "text": "木桥前的守兵还没有放行，暂时不能过去。",
      "soundId": "sfx-blocked"
    },
    {
      "id": "camp-quartermaster-line",
      "speakerName": "营地军需官",
      "speakerNpcId": "camp-quartermaster",
      "text": "前营补给都在这里。草药、绷带和备用短兵都能补上，缺什么自己挑。",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant"
    },
    {
      "id": "ford-camp-cache-line-open",
      "speakerName": "系统",
      "text": "你在前营堆放补给的木箱里找到了一卷绷带。",
      "soundId": "sfx-chest"
    }
  ],
