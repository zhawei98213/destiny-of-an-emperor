{
  "meta": {
    "id": "manual-story",
    "kind": "manual",
    "version": 1,
    "description": "Hand-authored chapter slice dialogue, events, and shop definitions."
  },
  "dialogueLines": [
    {
      "id": "intro-line-1",
      "speakerName": "村长",
      "speakerNpcId": "village-guide",
      "text": "东边的道路虽然重新开放了，可城外巡逻的人手还是不够。",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "intro-line-2",
      "speakerName": "村长",
      "speakerNpcId": "village-guide",
      "text": "你先去找补给官拿路引，出村以后路上随时都可能遇到敌兵。",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "lou-sang-shop-line",
      "speakerName": "补给官",
      "speakerNpcId": "merchant",
      "text": "这里是村里的补给铺。今天能卖的只有草药和几把简陋的兵器。",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant"
    },
    {
      "id": "lou-sang-pass-line",
      "speakerName": "补给官",
      "speakerNpcId": "merchant",
      "text": "村长已经打过招呼了。这份路引你收好，出村时给守门兵验一眼就行。",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant"
    },
    {
      "id": "lou-sang-guard-blocked-line",
      "speakerName": "守门兵",
      "speakerNpcId": "town-guard",
      "text": "站住。没有县里送来的路引，谁也不能离开楼桑村。",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "lou-sang-guard-open-line",
      "speakerName": "守门兵",
      "speakerNpcId": "town-guard",
      "text": "印记没错，我这就打开东门。你准备好了就从路标那边出去吧。",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "lou-sang-exit-line-blocked",
      "speakerName": "系统",
      "text": "东门还没有打开，暂时不能出村。",
      "soundId": "sfx-blocked"
    },
    {
      "id": "lou-sang-chest-line-open",
      "speakerName": "系统",
      "text": "你在村长家的储物罐里找到了一份草药。",
      "soundId": "sfx-chest"
    },
    {
      "id": "field-east-road-line",
      "speakerName": "系统",
      "text": "你沿着东路继续前进，前方能看见一座供往来行人歇脚的小驿站。",
      "soundId": "sfx-step"
    },
    {
      "id": "road-scout-line",
      "speakerName": "巡路兵",
      "speakerNpcId": "road-scout",
      "text": "前面的驿站还能歇脚，再往东可就不太平了。若是伤了筋骨，记得先回驿站整顿。",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "relay-rest-line",
      "speakerName": "驿站医官",
      "speakerNpcId": "relay-healer",
      "text": "先坐下缓口气吧。我替你把伤药和水袋都补齐，再上路也不迟。",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant"
    },
    {
      "id": "relay-cache-line-open",
      "speakerName": "系统",
      "text": "你在驿站角落的木箱里找到了一把铜剑。",
      "soundId": "sfx-chest"
    },
    {
      "id": "relay-post-east-line",
      "speakerName": "系统",
      "text": "你离开驿站，继续沿着东侧山道前进，前方就是渡口。",
      "soundId": "sfx-step"
    },
    {
      "id": "ford-clerk-line-issue",
      "speakerName": "渡口文吏",
      "speakerNpcId": "ford-clerk",
      "text": "前头要验文符。驿站那边已经报过你的名字，这枚渡口文符你先收着。",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "ford-clerk-line-repeat",
      "speakerName": "渡口文吏",
      "speakerNpcId": "ford-clerk",
      "text": "文符已经发给你了。过河时把它交给守兵验过，别在路上弄丢。",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "ford-guard-line-blocked",
      "speakerName": "渡口守兵",
      "speakerNpcId": "ford-guard",
      "text": "前面就是临河营地，没有渡口文符一律不得通行。",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "ford-guard-line-open",
      "speakerName": "渡口守兵",
      "speakerNpcId": "ford-guard",
      "text": "文符没问题，前面的木桥给你留着。顺着桥面过去就是前营。",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "ford-crossing-line-blocked",
      "speakerName": "系统",
      "text": "木桥前的守兵还没有放行，暂时不能过去。",
      "soundId": "sfx-blocked"
    },
    {
      "id": "camp-quartermaster-line",
      "speakerName": "营地军需官",
      "speakerNpcId": "camp-quartermaster",
      "text": "前营补给都在这里。草药、绷带和备用短兵都能补上，缺什么自己挑。",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant"
    },
    {
      "id": "ford-camp-cache-line-open",
      "speakerName": "系统",
      "text": "你在前营堆放补给的木箱里找到了一卷绷带。",
      "soundId": "sfx-chest"
    },
    {
      "id": "ridge-runner-line-issue",
      "speakerName": "前营文书",
      "speakerNpcId": "ridge-runner",
      "text": "山脊岗那边已经接到命令了。这枚山道符牌你拿好，到了岗亭再交给守兵验看。",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "ridge-runner-line-repeat",
      "speakerName": "前营文书",
      "speakerNpcId": "ridge-runner",
      "text": "山道符牌已经在你手里了。过岗时别忘了先让守兵验牌。",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "watch-clerk-line",
      "speakerName": "岗亭文吏",
      "speakerNpcId": "watch-clerk",
      "text": "山脊口外面就是前线营寨。牌符验过以后，你就能继续向东去整补。",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "watch-guard-line-blocked",
      "speakerName": "山口守兵",
      "speakerNpcId": "watch-guard",
      "text": "站住。没有山道符牌，任何人都不得通过岗亭东门。",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "watch-guard-line-open",
      "speakerName": "山口守兵",
      "speakerNpcId": "watch-guard",
      "text": "牌符无误。我这就放你过去，东边的山营已经给你留了位置。",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "ridgeway-gate-line-blocked",
      "speakerName": "系统",
      "text": "岗亭东门还没有放行，暂时不能继续前进。",
      "soundId": "sfx-blocked"
    },
    {
      "id": "ridge-quartermaster-line",
      "speakerName": "山营军需官",
      "speakerNpcId": "ridge-quartermaster",
      "text": "山营的干粮和伤药都在这里。路越往东越难走，先把包袱整齐了再说。",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant"
    },
    {
      "id": "ridgeway-cache-line-open",
      "speakerName": "系统",
      "text": "你在山营角落的补给箱里找到了一包行军口粮。",
      "soundId": "sfx-chest"
    },
    {
      "id": "pass-courier-line-issue",
      "speakerName": "山道传令兵",
      "speakerNpcId": "pass-courier",
      "text": "前头驿门正在盘查往来兵卒。这枚驿路铜牌你先拿着，见了守将再给他验看。",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "pass-courier-line-repeat",
      "speakerName": "山道传令兵",
      "speakerNpcId": "pass-courier",
      "text": "铜牌已经在你手里了。到了驿门别急着闯，先让守将验牌。",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "pass-scout-line",
      "speakerName": "高坡斥候",
      "speakerNpcId": "pass-scout",
      "text": "这段高坡白天也不安稳。乱兵就躲在坡背后，往前走时别把阵脚散了。",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "gate-captain-line-blocked",
      "speakerName": "驿门守将",
      "speakerNpcId": "gate-captain",
      "text": "没有驿路铜牌，谁也不能从这道门往东走。",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "gate-captain-line-open",
      "speakerName": "驿门守将",
      "speakerNpcId": "gate-captain",
      "text": "铜牌无误。我把东边驿院的门路给你放开，补给院那边已经在等你了。",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "highland-gate-line-blocked",
      "speakerName": "系统",
      "text": "驿门守将还没有放行，暂时不能继续向东。",
      "soundId": "sfx-blocked"
    },
    {
      "id": "supply-steward-line",
      "speakerName": "转运军需官",
      "speakerNpcId": "supply-steward",
      "text": "驿院的伤药和口粮都在这儿。再往前就是长线补给路，先把包袱扎紧了再上路。",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant"
    },
    {
      "id": "supply-cache-line-open",
      "speakerName": "系统",
      "text": "你在驿院角落的补给箱里翻出了一卷绷带。",
      "soundId": "sfx-chest"
    },
    {
      "id": "border-clerk-line-issue",
      "speakerName": "边关文吏",
      "speakerNpcId": "border-clerk",
      "text": "前营已经把文书送到了。你先拿着这道关印去见守兵，他验过之后才会开门。",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "border-clerk-line-repeat",
      "speakerName": "边关文吏",
      "speakerNpcId": "border-clerk",
      "text": "关印已经发给你了。别在门口拖延，守兵只认印记，不认空话。",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "border-sentry-line-blocked",
      "speakerName": "边关守兵",
      "speakerNpcId": "border-sentry",
      "text": "没有关印，任何人都不能穿过前面那道营门。",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "border-sentry-line-open",
      "speakerName": "边关守兵",
      "speakerNpcId": "border-sentry",
      "text": "印记无误。我这就把前营的门路让开，进营后先去找医官整备。",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "border-fort-gate-line-blocked",
      "speakerName": "系统",
      "text": "边关守兵还没有放行，前营大门暂时不会打开。",
      "soundId": "sfx-blocked"
    },
    {
      "id": "fort-healer-line",
      "speakerName": "关营医官",
      "speakerNpcId": "fort-healer",
      "text": "边营药具都在这儿。真要再往前冲，先把伤口包好，队列也重新整一遍。",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant"
    },
    {
      "id": "fort-cache-line-open",
      "speakerName": "系统",
      "text": "你在前营角落的补给箱里找到两卷绷带。",
      "soundId": "sfx-chest"
    },
    {
      "id": "border-fort-east-road-line",
      "speakerName": "系统",
      "text": "你穿过边关前院，继续沿着营墙向东推进，前方就是前营东路。",
      "soundId": "sfx-step"
    },
    {
      "id": "fort-adjutant-line-issue-1",
      "speakerName": "前营都尉",
      "speakerNpcId": "fort-adjutant",
      "text": "前营东侧还在盘查往来兵卒。你先把这道前营军令记在心里，到了门前别说错了。",
      "portraitId": "guide-default",
      "soundId": "voice-guide",
      "styleId": "dialogue-default"
    },
    {
      "id": "fort-adjutant-line-issue-2",
      "speakerName": "前营都尉",
      "speakerNpcId": "fort-adjutant",
      "text": "守兵点头之后，你就沿营墙往里走，粮官和斥候都在里面等着。",
      "portraitId": "guide-default",
      "soundId": "voice-guide",
      "styleId": "dialogue-default"
    },
    {
      "id": "fort-adjutant-line-repeat",
      "speakerName": "前营都尉",
      "speakerNpcId": "fort-adjutant",
      "text": "军令已经交代给你了。别在门口耽搁，前营里面还有人等着回报。",
      "portraitId": "guide-default",
      "soundId": "voice-guide",
      "styleId": "dialogue-default"
    },
    {
      "id": "camp-sentry-line-blocked",
      "speakerName": "前营守兵",
      "speakerNpcId": "camp-sentry",
      "text": "没有都尉那边的军令，谁也不能再往里走。",
      "portraitId": "guard-default",
      "soundId": "voice-guard",
      "styleId": "dialogue-default"
    },
    {
      "id": "camp-sentry-line-open",
      "speakerName": "前营守兵",
      "speakerNpcId": "camp-sentry",
      "text": "军令核对无误。你跟着营墙往东进，里面就是前营补给场。",
      "portraitId": "guard-default",
      "soundId": "voice-guard",
      "styleId": "dialogue-default"
    },
    {
      "id": "forward-camp-gate-line-open",
      "speakerName": "系统",
      "text": "守兵让开身位，你顺着东侧营墙继续向前。",
      "soundId": "sfx-step"
    },
    {
      "id": "forward-camp-gate-line-blocked",
      "speakerName": "系统",
      "text": "前营守兵还没有放行，东侧营道暂时不能通过。",
      "soundId": "sfx-blocked"
    },
    {
      "id": "forward-camp-shop-line",
      "speakerName": "前营粮官",
      "speakerNpcId": "camp-purveyor",
      "text": "前营口粮、草药和备用短兵都在这里。要是准备继续前推，就先把包袱整好。",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant",
      "styleId": "dialogue-default"
    },
    {
      "id": "forward-camp-cache-line-open",
      "speakerName": "系统",
      "text": "你在补给场角落的木箱里找到一卷绷带和一份草药。",
      "soundId": "sfx-chest"
    }
  ],
  "events": [
