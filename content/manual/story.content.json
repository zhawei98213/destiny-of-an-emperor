      "name": "Road Scout Event",
      "steps": [
        { "type": "dialogue", "lineId": "road-scout-line" },
        { "type": "end" }
      ]
    },
    {
      "id": "relay-rest-event",
      "name": "Relay Rest Event",
      "steps": [
        { "type": "dialogue", "lineId": "relay-rest-line" },
        { "type": "restoreParty" },
        { "type": "playSfx", "sfxId": "sfx-rest" },
        { "type": "end" }
      ]
    },
    {
      "id": "relay-cache-event",
      "name": "Relay Cache Event",
      "steps": [
