{
  "meta": {
    "id": "manual-story",
    "kind": "manual",
    "version": 1,
    "description": "Hand-authored chapter slice dialogue, events, and shop definitions."
  },
  "dialogueLines": [
    {
      "id": "intro-line-1",
      "speakerName": "Village Elder",
      "speakerNpcId": "village-guide",
      "text": "The eastern road has reopened, but the patrols are still thin beyond the gate.",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "intro-line-2",
      "speakerName": "Village Elder",
      "speakerNpcId": "village-guide",
      "text": "Speak with the quartermaster, take the road pass, and be ready for the first skirmish outside town.",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "lou-sang-shop-line",
      "speakerName": "Supply Keeper",
      "speakerNpcId": "merchant",
      "text": "This is the village supply counter. Herbs and simple blades are all I can sell today.",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant"
    },
    {
      "id": "lou-sang-guard-blocked-line",
      "speakerName": "Gate Watch",
      "speakerNpcId": "town-guard",
      "text": "Stop. No one leaves Lou Sang Village without the road pass from the county messenger.",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "lou-sang-guard-open-line",
      "speakerName": "Gate Watch",
      "speakerNpcId": "town-guard",
      "text": "The seal is in order. I will open the east gate. Step onto the road marker when you are ready.",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "lou-sang-exit-line-blocked",
      "speakerName": "System",
      "text": "The east gate is still barred from inside the village.",
      "soundId": "sfx-blocked"
    },
    {
      "id": "lou-sang-chest-line-open",
      "speakerName": "System",
      "text": "You found one Herb in the elder's store jar.",
      "soundId": "sfx-chest"
    },
    {
      "id": "battle-start-line",
      "speakerName": "System",
      "text": "A roaming patrol spots you on the eastern road.",
      "soundId": "sfx-battle-alert"
    }
  ],
  "events": [
    {
      "id": "intro-event",
      "name": "Intro Event",
      "steps": [
        {
          "type": "dialogue",
          "lineId": "intro-line-1"
        },
        {
          "type": "dialogue",
          "lineId": "intro-line-2"
        },
        {
          "type": "setFlag",
          "flagId": "intro-complete",
          "value": true
        },
        {
          "type": "end"
        }
      ]
    },
    {
      "id": "lou-sang-shop-event",
      "name": "Lou Sang Shop Event",
      "steps": [
        { "type": "dialogue", "lineId": "lou-sang-shop-line" },
        { "type": "setFlag", "flagId": "merchant-met" },
        { "type": "openShop", "shopId": "starter-shop" },
        { "type": "playSfx", "sfxId": "sfx-shop-open" },
        { "type": "end" }
      ]
    },
    {
      "id": "lou-sang-guard-event",
      "name": "Lou Sang Guard Event",
      "steps": [
        {
          "type": "ifNotFlag",
          "flagId": "gate-pass",
          "steps": [
            { "type": "dialogue", "lineId": "lou-sang-guard-blocked-line" },
            { "type": "end" }
          ]
        },
        {
          "type": "ifFlag",
          "flagId": "gate-pass",
          "steps": [
            { "type": "dialogue", "lineId": "lou-sang-guard-open-line" },
            { "type": "setFlag", "flagId": "lou-sang-east-gate-open" },
            { "type": "playSfx", "sfxId": "sfx-gate-open" },
            { "type": "end" }
          ]
        },
        { "type": "end" }
      ]
    },
    {
      "id": "lou-sang-east-exit-event",
      "name": "Lou Sang East Exit Event",
      "steps": [
        {
          "type": "ifNotFlag",
          "flagId": "lou-sang-east-gate-open",
          "steps": [
            { "type": "dialogue", "lineId": "lou-sang-exit-line-blocked" },
            { "type": "end" }
          ]
        },
        {
          "type": "ifFlag",
          "flagId": "lou-sang-east-gate-open",
          "steps": [
            { "type": "warp", "targetMapId": "field", "targetSpawnId": "field-gate" },
            { "type": "end" }
          ]
        },
        { "type": "end" }
      ]
    },
    {
      "id": "lou-sang-chest-event",
      "name": "Lou Sang Chest Event",
      "steps": [
        { "type": "dialogue", "lineId": "lou-sang-chest-line-open" },
        { "type": "giveItem", "itemId": "herb", "quantity": 1 },
        { "type": "setFlag", "flagId": "town-chest-opened" },
        { "type": "playSfx", "sfxId": "sfx-chest" },
        { "type": "end" }
      ]
    },
    {
      "id": "training-battle-event",
      "name": "Training Battle Event",
      "steps": [
        { "type": "dialogue", "lineId": "battle-start-line" },
        { "type": "playSfx", "sfxId": "sfx-battle-alert" },
        { "type": "startBattle", "battleGroupId": "training-slimes" },
        { "type": "end" }
      ]
    }
  ],
  "shops": [
    {
      "id": "starter-shop",
      "name": "Lou Sang Supply Counter",
      "inventory": [
        {
          "itemId": "herb"
        },
        {
          "itemId": "bronze-sword",
          "price": 40
        }
      ]
    }
  ]
}
