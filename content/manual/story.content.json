{
  "meta": {
    "id": "manual-story",
    "kind": "manual",
    "version": 1,
    "description": "Hand-authored dialogue, events, and shop definitions."
  },
  "dialogueLines": [
    {
      "id": "intro-line-1",
      "speakerName": "Village Guide",
      "speakerNpcId": "village-guide",
      "text": "The road ahead is clear enough for a systems demo.",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "intro-line-2",
      "speakerName": "Village Guide",
      "speakerNpcId": "village-guide",
      "text": "Talk to the merchant or enter the training yard.",
      "portraitId": "guide-default",
      "soundId": "voice-guide"
    },
    {
      "id": "merchant-line-1",
      "speakerName": "Merchant",
      "speakerNpcId": "merchant",
      "text": "I only stock placeholder wares, but the data path is real.",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant"
    },
    {
      "id": "merchant-line-2",
      "speakerName": "Merchant",
      "speakerNpcId": "merchant",
      "text": "Take this pass and show it to the guard by the east gate.",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant"
    },
    {
      "id": "guard-line-blocked",
      "speakerName": "Town Guard",
      "speakerNpcId": "town-guard",
      "text": "Hold it. No one leaves town without a merchant pass.",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "guard-line-open",
      "speakerName": "Town Guard",
      "speakerNpcId": "town-guard",
      "text": "Pass confirmed. You may head into the field now.",
      "portraitId": "guard-default",
      "soundId": "voice-guard"
    },
    {
      "id": "chest-line-open",
      "speakerName": "System",
      "text": "You found an Herb in the chest.",
      "soundId": "sfx-chest"
    }
  ],
  "events": [
    {
      "id": "intro-event",
      "name": "Intro Event",
      "steps": [
        {
          "type": "dialogue",
          "lineId": "intro-line-1"
        },
        {
          "type": "dialogue",
          "lineId": "intro-line-2"
        },
        {
          "type": "setFlag",
          "flagId": "intro-complete",
          "value": true
        },
        {
          "type": "end"
        }
      ]
    },
    {
      "id": "merchant-pass-event",
      "name": "Merchant Pass Event",
      "steps": [
        { "type": "dialogue", "lineId": "merchant-line-1" },
        { "type": "dialogue", "lineId": "merchant-line-2" },
        { "type": "setFlag", "flagId": "merchant-met" },
        { "type": "setFlag", "flagId": "gate-pass" },
        { "type": "playSfx", "sfxId": "sfx-pass" },
        { "type": "end" }
      ]
    },
    {
      "id": "guard-gate-event",
      "name": "Guard Gate Event",
      "steps": [
        {
          "type": "ifNotFlag",
          "flagId": "gate-pass",
          "steps": [
            { "type": "dialogue", "lineId": "guard-line-blocked" },
            { "type": "end" }
          ]
        },
        {
          "type": "ifFlag",
          "flagId": "gate-pass",
          "steps": [
            { "type": "dialogue", "lineId": "guard-line-open" },
            { "type": "warp", "targetMapId": "field", "targetSpawnId": "field-gate" },
            { "type": "end" }
          ]
        }
      ]
    },
    {
      "id": "town-chest-event",
      "name": "Town Chest Event",
      "steps": [
        { "type": "dialogue", "lineId": "chest-line-open" },
        { "type": "giveItem", "itemId": "herb", "quantity": 1 },
        { "type": "setFlag", "flagId": "town-chest-opened" },
        { "type": "playSfx", "sfxId": "sfx-chest" },
        { "type": "end" }
      ]
    },
    {
      "id": "training-battle-event",
      "name": "Training Battle Event",
      "steps": [
        { "type": "playSfx", "sfxId": "sfx-battle-alert" },
        { "type": "startBattle", "battleGroupId": "training-slimes" },
        { "type": "end" }
      ]
    }
  ],
  "shops": [
    {
      "id": "starter-shop",
      "name": "Starter Shop",
      "inventory": [
        {
          "itemId": "herb"
        },
        {
          "itemId": "bronze-sword",
          "price": 40
        }
      ]
    }
  ]
}
