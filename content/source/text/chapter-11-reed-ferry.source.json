{
  "format": "text-source-v1",
  "chapterId": "chapter-11-reed-ferry",
  "title": "Reed Ferry Crossing",
  "notes": "Chapter-11 reed ferry road and camp dialogue source. / 第 11 章芦渡前路与渡营对白源。",
  "dialogueLines": [
    {
      "id": "reed-clerk-line-issue",
      "speakerName": "渡口文吏",
      "speakerNpcId": "reed-clerk",
      "text": "前头就是芦渡。把这道渡口军文交给守兵，他才会放你过去。",
      "portraitId": "guide-default",
      "styleId": "dialogue-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-11",
      "soundId": "voice-guide"
    },
    {
      "id": "reed-clerk-line-repeat",
      "speakerName": "渡口文吏",
      "speakerNpcId": "reed-clerk",
      "text": "渡口军文已经发给你了，别在芦苇滩里乱闯。",
      "portraitId": "guide-default",
      "styleId": "dialogue-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-11",
      "soundId": "voice-guide"
    },
    {
      "id": "reed-sentry-line-blocked",
      "speakerName": "渡口守兵",
      "speakerNpcId": "reed-sentry",
      "text": "没有军文，谁也不能靠近渡口木桥。",
      "portraitId": "guard-default",
      "styleId": "dialogue-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-11",
      "soundId": "voice-guard"
    },
    {
      "id": "reed-sentry-line-open",
      "speakerName": "渡口守兵",
      "speakerNpcId": "reed-sentry",
      "text": "军文无误。把木桥放下来，让他们进渡营。",
      "portraitId": "guard-default",
      "styleId": "dialogue-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-11",
      "soundId": "voice-guard"
    },
    {
      "id": "reed-gate-line-blocked",
      "speakerName": "系统",
      "text": "渡口木桥还没有放下。",
      "portraitId": "system-default",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-11",
      "soundId": "sfx-blocked"
    },
    {
      "id": "reed-gate-line-open",
      "speakerName": "系统",
      "text": "木桥缓缓落下，前方就是芦渡营地。",
      "portraitId": "system-default",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-11",
      "soundId": "sfx-gate-open"
    },
    {
      "id": "reed-shop-line",
      "speakerName": "渡营粮官",
      "speakerNpcId": "reed-quartermaster",
      "text": "渡口补给都在这里。过河前，把药草和口粮都补齐。",
      "portraitId": "merchant-default",
      "styleId": "dialogue-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-11",
      "soundId": "voice-merchant"
    },
    {
      "id": "reed-cache-line-open",
      "speakerName": "系统",
      "text": "木箱里剩下一卷绷带和一包口粮。",
      "portraitId": "system-default",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-11",
      "soundId": "sfx-chest"
    }
  ],
