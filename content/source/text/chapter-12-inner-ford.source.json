  "title": "Inner Ford Approach",
  "notes": "Chapter-12 inner ford road and camp dialogue source. / 第 12 章内渡前路与内渡营对白源。",
  "dialogueLines": [
    {
      "id": "inner-ford-clerk-line-issue",
      "speakerName": "内渡文吏",
      "speakerNpcId": "inner-ford-clerk",
      "text": "再往前就是内渡河口。拿这道内渡军文去给守兵看，他才会放桥。",
      "portraitId": "guide-default",
      "styleId": "dialogue-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-12",
      "soundId": "voice-guide"
    },
    {
      "id": "inner-ford-clerk-line-repeat",
      "speakerName": "内渡文吏",
      "speakerNpcId": "inner-ford-clerk",
      "text": "内渡军文已经交给你了，别在河口外侧多停留。",
      "portraitId": "guide-default",
      "styleId": "dialogue-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-12",
      "soundId": "voice-guide"
    },
    {
      "id": "inner-ford-sentry-line-blocked",
      "speakerName": "内渡守兵",
      "speakerNpcId": "inner-ford-sentry",
      "text": "没有内渡军文，谁也不能靠近浮桥。",
      "portraitId": "guard-default",
      "styleId": "dialogue-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-12",
      "soundId": "voice-guard"
    },
    {
      "id": "inner-ford-sentry-line-open",
      "speakerName": "内渡守兵",
      "speakerNpcId": "inner-ford-sentry",
      "text": "军文无误。把浮桥放稳，让他们进内渡营。",
      "portraitId": "guard-default",
      "styleId": "dialogue-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-12",
      "soundId": "voice-guard"
    },
    {
      "id": "inner-ford-gate-line-blocked",
      "speakerName": "系统",
      "text": "浮桥还没有稳稳搭好。",
      "portraitId": "system-default",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-12",
      "soundId": "sfx-blocked"
    },
    {
      "id": "inner-ford-gate-line-open",
      "speakerName": "系统",
      "text": "浮桥被放下，前方就是内渡营地。",
      "portraitId": "system-default",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-12",
      "soundId": "sfx-gate-open"
    },
    {
      "id": "inner-ford-shop-line",
      "speakerName": "内渡粮官",
      "speakerNpcId": "inner-ford-quartermaster",
      "text": "过内渡前先把药草和干粮补齐，这里就是前队最后一处补给点。",
      "portraitId": "merchant-default",
      "styleId": "dialogue-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-12",
      "soundId": "voice-merchant"
    },
    {
      "id": "inner-ford-cache-line-open",
      "speakerName": "系统",
      "text": "木箱里压着一卷绷带和一包干粮。",
      "portraitId": "system-default",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-12",
      "soundId": "sfx-chest"
    }
  ],
