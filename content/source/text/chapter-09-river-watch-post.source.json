  "dialogueLines": [
    {
      "id": "bank-clerk-line-issue",
      "speakerName": "河岸文吏",
      "speakerNpcId": "bank-clerk",
      "text": "前面的河营正在换防。你先记下这道河岸军令，到了木栅前再让守兵验过。",
      "portraitId": "guide-default",
      "soundId": "voice-guide",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-09"
    },
    {
      "id": "bank-clerk-line-repeat",
      "speakerName": "河岸文吏",
      "speakerNpcId": "bank-clerk",
      "text": "河岸军令已经交给你了。守兵只认军令，不认口头传话。",
      "portraitId": "guide-default",
      "soundId": "voice-guide",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-09"
    },
    {
      "id": "bank-sentry-line-blocked",
      "speakerName": "河岸守兵",
      "speakerNpcId": "bank-sentry",
      "text": "木栅后面就是河营，没有军令一律不准通行。",
      "portraitId": "guard-default",
      "soundId": "voice-guard",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-09"
    },
    {
      "id": "bank-sentry-line-open",
      "speakerName": "河岸守兵",
      "speakerNpcId": "bank-sentry",
      "text": "军令无误。我先把木栅给你放开，过去就是河营补给哨。",
      "portraitId": "guard-default",
      "soundId": "voice-guard",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-09"
    },
    {
      "id": "river-watch-gate-line-blocked",
      "speakerName": "系统",
      "text": "木栅还没有放行，暂时不能继续向东。",
      "portraitId": "system-default",
      "soundId": "sfx-blocked",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-09"
    },
    {
      "id": "river-watch-gate-line-open",
      "speakerName": "系统",
      "text": "你穿过河岸木栅，前面就是河营补给哨。",
      "portraitId": "system-default",
      "soundId": "sfx-step",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-09"
    },
    {
      "id": "river-watch-shop-line",
      "speakerName": "河营粮官",
      "speakerNpcId": "watch-quartermaster",
      "text": "河营用的干粮、绷带和短兵都在这里。过河之前，最好先把行装补齐。",
      "portraitId": "merchant-default",
      "soundId": "voice-merchant",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-09"
    },
    {
      "id": "river-watch-cache-line-open",
      "speakerName": "系统",
      "text": "你在河营角落的补给箱里找到了一包行军口粮和一卷绷带。",
      "portraitId": "system-default",
      "soundId": "sfx-chest",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-09"
    }
  ],
