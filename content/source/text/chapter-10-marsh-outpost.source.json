  "chapterId": "chapter-10-marsh-outpost",
  "title": "Marsh Outpost Advance",
  "notes": "Chapter-10 marsh road and outpost dialogue source. / 第 10 章沼泽前路与沼营哨所对白源。",
  "dialogueLines": [
    {
      "id": "marsh-clerk-line-issue",
      "speakerName": "沼地文吏",
      "text": "前头就是沼营木栅。拿着这道湿地军令去见守兵，别在泥地里乱闯。",
      "portraitId": "system-default",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-10",
      "soundId": "sfx-confirm"
    },
    {
      "id": "marsh-clerk-line-repeat",
      "speakerName": "沼地文吏",
      "text": "军令已经发给你了。过了木栅，沼营里自会有人接应。",
      "portraitId": "system-default",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-10",
      "soundId": "sfx-confirm"
    },
    {
      "id": "marsh-sentry-line-blocked",
      "speakerName": "沼地守兵",
      "text": "没有湿地军令，谁也不准靠近木栅。",
      "portraitId": "system-default",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-10",
      "soundId": "sfx-confirm"
    },
    {
      "id": "marsh-sentry-line-open",
      "speakerName": "沼地守兵",
      "text": "军令无误。把木栅抬起，放他们进沼营。",
      "portraitId": "system-default",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-10",
      "soundId": "sfx-gate-open"
    },
    {
      "id": "marsh-gate-line-blocked",
      "speakerName": "系统",
      "text": "木栅还没有打开。",
      "portraitId": "system-default",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-10",
      "soundId": "sfx-confirm"
    },
    {
      "id": "marsh-gate-line-open",
      "speakerName": "系统",
      "text": "木栅缓缓抬起，前方就是沼营哨所。",
      "portraitId": "system-default",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-10",
      "soundId": "sfx-gate-open"
    },
    {
      "id": "marsh-shop-line",
      "speakerName": "沼营粮官",
      "text": "湿地补给都在这里。药草、口粮和刀剑，自己挑吧。",
      "portraitId": "system-default",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-10",
      "soundId": "sfx-shop-open"
    },
    {
      "id": "marsh-cache-line-open",
      "speakerName": "系统",
      "text": "木箱里还剩下一点干粮和药带。",
      "portraitId": "system-default",
      "styleId": "system-default",
      "locale": "zh-CN",
      "revisionTag": "chapter-10",
      "soundId": "sfx-chest"
    }
  ],
